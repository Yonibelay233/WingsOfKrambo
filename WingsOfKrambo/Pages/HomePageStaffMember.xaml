<Page x:Class="WingsOfKrambo.Pages.HomePageStaffMember"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WingsOfKrambo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePageStaffMember">

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                <TextBlock Text="מרכז שליטה - איש צוות" Foreground="White" VerticalAlignment="Center" FontSize="18" FontWeight="Light" Margin="0,0,15,0"/>
                <Image Source="/Pictures/Logo.png" Height="55"/>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="2" Margin="40">

            <Button Margin="15" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="👥" FontSize="45" HorizontalAlignment="Center"/>
                    <TextBlock Text="ניהול רשימות" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="📊" FontSize="45" HorizontalAlignment="Center"/>
                    <TextBlock Text="דוחות פעילות" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="📆" FontSize="45" HorizontalAlignment="Center"/>
                    <TextBlock Text="לו''ז שבועי" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="⚙️" FontSize="45" HorizontalAlignment="Center"/>
                    <TextBlock Text="הגדרות מערכת" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Page>
