<Page x:Class="WingsOfKrambo.Pages.HomeGuidePage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WingsOfKrambo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomeGuidePage1">

   
        <Grid Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0056A4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                    <TextBlock Text="שלום, מדריך!" Foreground="White" FontSize="24" VerticalAlignment="Center" FontWeight="Bold"/>
                    <Image Source="/Pictures/Logo.png" Height="60" Margin="20,0,0,0"/>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="1" Columns="2" Margin="30">
            <!-- כפתור דיווח נוכחות -->
            <Button Margin="10" Background="White" BorderBrush="#FBBCD0" BorderThickness="2" Click="AttendanceReport_Click">
                <StackPanel>
                    <Image Source="/Pictures/Logo.png" Height="60" Margin="0,0,0,10"/>
                    <TextBlock Text="דיווח נוכחות" FontSize="18" FontWeight="Bold" Foreground="#FF005A9C" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Margin="10" Background="White" BorderBrush="#FF8C00" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="לוח פעילויות" FontSize="18" FontWeight="Bold" Foreground="#FF8C00"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Grid>
</Page>