<Page x:Class="WingsOfKrambo.Pages.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WingsOfKrambo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogIn">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Image Grid.Row="0" Source="/Pictures/Logo.png" Height="120" Margin="0,0,0,20" 
               Stretch="Uniform" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="ברוכים הבאים לסניף!" 
                   FontSize="22" FontWeight="Bold" Foreground="#0056A4" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <StackPanel Grid.Row="2" VerticalAlignment="Top">
            <TextBlock Text="שם פרטי:" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox x:Name="txtFirst" Height="35" Margin="0,0,0,15" Padding="5" 
                     VerticalContentAlignment="Center" BorderBrush="#DDD" />

            <TextBlock Text="תעודת זהות:" Margin="0,0,0,5" Foreground="#555"/>
           <PasswordBox x:Name="txtID" Height="30" VerticalContentAlignment="Center"/>

                <TextBox x:Name="txtIDVisible" Height="30" VerticalContentAlignment="Center" 
 Visibility="Collapsed"/>

                <Button x:Name="btnShowPass" Content="👁" Width="30" HorizontalAlignment="Right" 
PreviewMouseDown="btnShowPass_PreviewMouseDown" 
PreviewMouseUp="btnShowPass_PreviewMouseUp"
MouseLeave="btnShowPass_MouseLeave"/> 

            <CheckBox x:Name="RememberMeCheckBox" Content="זכור אותי" Margin="0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Width="200">
            <Button Content="כניסה" Height="40" Background="#0056A4" Foreground="White" 
                    FontSize="16" FontWeight="Bold" Cursor="Hand" Click="btnLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <TextBlock Text="אין משתמש? " Foreground="#666"/>
                <TextBlock Text="הירשם!" Foreground="#FF8C00" FontWeight="Bold" 
                           Cursor="Hand" MouseLeftButtonDown="Register_Click"
                           />
            </StackPanel>
        </StackPanel>
       
    </Grid>
</Page>
