<Page x:Class="WingsOfKrambo.Pages.HPageApprentice"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WingsOfKrambo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HPageApprentice">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF8C00">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0">
                <TextBlock x:Name="lblWelcome" Text="!שלום, חניך" Foreground="White" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="0,0,10,0"/>
                <Image Source="/Pictures/Logo.png" Height="60"/>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="2" Margin="30">

            <Button Margin="10" Background="White" BorderBrush="#FF8C00" BorderThickness="2" Click="OpenActions">
                <StackPanel>
                    <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="הפעילויות שלי" FontSize="18" FontWeight="Bold" Foreground="#FF8C00" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="10" Background="White" BorderBrush="#0056A4" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="💬" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="דבר עם המדריך" FontSize="18" FontWeight="Bold" Foreground="#0056A4" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnUploadImages" 
                Click="BtnUploadImages_Click"
                Margin="10" Background="White" BorderBrush="#0056A4" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="📷" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="תמונות מהפעולה" FontSize="18" FontWeight="Bold" Foreground="#0056A4" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="10" Background="White" BorderBrush="#FF8C00" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="הפרופיל שלי" FontSize="18" FontWeight="Bold" Foreground="#FF8C00" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Page>
