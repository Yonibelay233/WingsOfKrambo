<Page x:Class="WingsOfKrambo.Pages.HomePageChildWithSpecialNeeds"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WingsOfKrambo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePageChildWithSpecialNeeds">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="היי! איזה כיף שבאת" FontSize="40" FontWeight="Bold" Foreground="#FF6F00" VerticalAlignment="Center"/>
            <TextBlock Text=" 😊" FontSize="50" VerticalAlignment="Center"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2">

            <Button Margin="15" Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="5" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🎈" FontSize="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="מה עושים היום?" FontSize="28" FontWeight="Bold" Foreground="#1565C0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="#F1F8E9" BorderBrush="#4CAF50" BorderThickness="5" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="👫" FontSize="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="החברים שלי" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="5" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🖼️" FontSize="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="התמונות שלי" FontSize="28" FontWeight="Bold" Foreground="#E65100" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Margin="15" Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="5" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="🙋‍♂️" FontSize="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="אני צריך עזרה" FontSize="28" FontWeight="Bold" Foreground="#C62828" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</Page>
